#!/usr/bin/env bash
# cvm — Claude VM
# Runs 'claude --dangerously-skip-permissions -p' inside a Docker container
# or VM (KVM/VirtualBox/VMware) for isolated, fully autonomous task execution.
set -euo pipefail

# ── Version ───────────────────────────────────────────────────────────────────
VERSION="0.2.0"

# ── Defaults ──────────────────────────────────────────────────────────────────
MODEL="claude-sonnet-4-6"
BACKEND=""          # empty = auto-detect
DIR=""
KEEP=false
OUT=""
BUDGET=""
FORCE_BUILD=false
NO_COLOR=false
VERBOSE=false
TASK=""

# VM runtime state (used by cleanup/interrupt handlers)
VM_PID=""           # KVM qemu PID
VM_NAME=""          # VirtualBox task VM name
VM_TASK_DIR=""      # VMware task directory path
VM_PORT=""          # SSH port for VM backends
VMWARE_PROVIDER=""  # ws, fusion, or player

# ── Named VM config ────────────────────────────────────────────────────────────
CVM_CONFIG_DIR="$HOME/.config/cvm"
CVM_VMS_DIR="$CVM_CONFIG_DIR/vms"
CVM_REGISTRY="$CVM_CONFIG_DIR/vms.json"

# ── Colors ────────────────────────────────────────────────────────────────────
# Initialize with color codes by default; setup_colors() clears them if needed
RED=$'\033[0;31m'
YELLOW=$'\033[0;33m'
GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'

setup_colors() {
    if [[ "$NO_COLOR" == "true" ]] || [[ ! -t 1 ]]; then
        RED="" YELLOW="" GREEN="" CYAN="" BOLD="" DIM="" RESET=""
    fi
}

# ── Logging ───────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}[cvm]${RESET} $*"; }
success() { echo -e "${GREEN}[cvm]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[cvm]${RESET} $*" >&2; }
error()   { echo -e "${RED}[cvm] error:${RESET} $*" >&2; }
die()     { error "$*"; exit 1; }

# ── Named VM Registry ─────────────────────────────────────────────────────────
registry_ensure() {
    mkdir -p "$CVM_VMS_DIR"
    if [[ ! -f "$CVM_REGISTRY" ]]; then
        echo '{}' > "$CVM_REGISTRY"
    fi
}

registry_get_field() {
    local name="$1" field="$2"
    python3 - "$CVM_REGISTRY" "$name" "$field" <<'PYEOF'
import json, sys
reg_file, name, field = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(reg_file) as f:
        data = json.load(f)
    vm = data.get(name)
    if vm is None:
        sys.exit(1)
    v = vm.get(field)
    if v is not None:
        print(v)
except Exception:
    sys.exit(1)
PYEOF
}

registry_set() {
    local name="$1" json_blob="$2"
    python3 - "$CVM_REGISTRY" "$name" "$json_blob" <<'PYEOF'
import json, sys
reg_file, name, blob_str = sys.argv[1], sys.argv[2], sys.argv[3]
blob = json.loads(blob_str)
try:
    with open(reg_file) as f:
        data = json.load(f)
except Exception:
    data = {}
data[name] = blob
with open(reg_file, 'w') as f:
    json.dump(data, f, indent=2)
PYEOF
}

registry_delete() {
    local name="$1"
    python3 - "$CVM_REGISTRY" "$name" <<'PYEOF'
import json, sys
reg_file, name = sys.argv[1], sys.argv[2]
try:
    with open(reg_file) as f:
        data = json.load(f)
    data.pop(name, None)
    with open(reg_file, 'w') as f:
        json.dump(data, f, indent=2)
except Exception:
    pass
PYEOF
}

registry_list_all() {
    python3 - "$CVM_REGISTRY" <<'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print(json.dumps(list(data.values()), indent=2))
except Exception:
    print('[]')
PYEOF
}

registry_exists() {
    local name="$1"
    python3 - "$CVM_REGISTRY" "$name" <<'PYEOF'
import json, sys
reg_file, name = sys.argv[1], sys.argv[2]
try:
    with open(reg_file) as f:
        data = json.load(f)
    sys.exit(0 if name in data else 1)
except Exception:
    sys.exit(1)
PYEOF
}

# ── VM State Helpers ──────────────────────────────────────────────────────────
vm_is_running() {
    local name="$1" backend="$2"
    case "$backend" in
        kvm)
            local pid_file="/tmp/cvm-${name}.pid"
            if [[ -f "$pid_file" ]]; then
                local pid
                pid="$(cat "$pid_file" 2>/dev/null)"
                if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
                    return 0
                fi
                # Stale PID file
                rm -f "$pid_file" "/tmp/cvm-${name}.port"
            fi
            return 1
            ;;
        virtualbox)
            local vbox_name="cvm-${name}"
            local state
            state="$(VBoxManage showvminfo "$vbox_name" --machinereadable 2>/dev/null \
                | grep '^VMState=' | cut -d'"' -f2 || true)"
            [[ "$state" == "running" ]]
            ;;
        docker)
            return 1
            ;;
        *)
            return 1
            ;;
    esac
}

vm_get_port() {
    local name="$1"
    local port_file="/tmp/cvm-${name}.port"
    if [[ -f "$port_file" ]]; then
        cat "$port_file"
    fi
}

vm_named_start() {
    local name="$1"
    local backend
    backend="$(registry_get_field "$name" backend)"
    case "$backend" in
        kvm)        kvm_vm_start "$name" ;;
        virtualbox) vbox_vm_start "$name" ;;
        docker)     return 0 ;;
        *) die "Unknown backend: $backend" ;;
    esac
}

vm_named_stop() {
    local name="$1"
    local backend
    backend="$(registry_get_field "$name" backend)"
    case "$backend" in
        kvm)        kvm_vm_stop "$name" ;;
        virtualbox) vbox_vm_stop "$name" ;;
        docker)     return 0 ;;
        *) die "Unknown backend: $backend" ;;
    esac
}

