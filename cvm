# ── Argument parsing ──────────────────────────────────────────────────────────
parse_args() {
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)
                [[ $# -lt 2 ]] && die "--dir requires an argument"
                DIR="$2"; shift 2 ;;
            -k|--keep)
                KEEP=true; shift ;;
            -m|--model)
                [[ $# -lt 2 ]] && die "--model requires an argument"
                MODEL="$2"; shift 2 ;;
            -o|--out)
                [[ $# -lt 2 ]] && die "--out requires an argument"
                OUT="$2"; shift 2 ;;
            -b|--budget)
                [[ $# -lt 2 ]] && die "--budget requires an argument"
                BUDGET="$2"; shift 2 ;;
            --backend)
                [[ $# -lt 2 ]] && die "--backend requires an argument"
                BACKEND="$2"; shift 2 ;;
            --build)
                FORCE_BUILD=true; shift ;;
            --no-color)
                NO_COLOR=true; shift ;;
            -v|--verbose)
                VERBOSE=true; shift ;;
            -h|--help)
                show_help; exit 0 ;;
            --version)
                echo "cvm $VERSION"; exit 0 ;;
            --)
                shift; args+=("$@"); break ;;
            -*)
                die "Unknown option: $1" ;;
            *)
                args+=("$1"); shift ;;
        esac
    done

    # Join remaining args as the task
    if [[ ${#args[@]} -gt 0 ]]; then
        TASK="${args[*]}"
    fi

    # Read from stdin if piped and no task given
    if [[ -z "$TASK" ]] && [[ ! -t 0 ]]; then
        TASK="$(cat)"
    fi

    if [[ -z "$TASK" ]]; then
        show_help
        echo ""
        die "No task provided. Pass a task as an argument or pipe it via stdin."
    fi

    # Validate backend if explicitly specified
    if [[ -n "$BACKEND" ]]; then
        case "$BACKEND" in
            docker|kvm|virtualbox|vmware) ;;
            *) die "Unknown backend: $BACKEND (valid: docker, kvm, virtualbox, vmware)" ;;
        esac
    fi
}

# ── Backend detection ─────────────────────────────────────────────────────────
detect_backend() {
    if [[ -n "$BACKEND" ]]; then
        [[ "$VERBOSE" == "true" ]] && info "Backend: $BACKEND (explicit)"
        return 0
    fi

    # Auto-detect: try in order of preference
    if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
        BACKEND="docker"
    elif [[ -e /dev/kvm ]] && command -v qemu-system-x86_64 &>/dev/null; then
        BACKEND="kvm"
    elif command -v VBoxManage &>/dev/null; then
        BACKEND="virtualbox"
    elif command -v vmrun &>/dev/null; then
        BACKEND="vmware"
    else
        die "No supported backend found. Install one of:
  Docker:     https://docs.docker.com/get-docker/
  KVM/QEMU:   apt install qemu-system-x86 qemu-utils cloud-image-utils
  VirtualBox: https://www.virtualbox.org/
  VMware:     https://www.vmware.com/"
    fi

    info "Backend: $BACKEND (auto-detected)"
}

# ── Dependency checks ─────────────────────────────────────────────────────────
docker_check_deps() {
    if ! command -v docker &>/dev/null; then
        die "docker not found in PATH.
  On WSL: Enable WSL Integration in Docker Desktop:
    Settings > Resources > WSL Integration > Enable for your distro"
    fi

    if ! docker info &>/dev/null; then
        die "Docker is not running or not accessible.
  Start Docker Desktop on Windows, then wait a few seconds and retry."
    fi
}

kvm_check_deps() {
    command -v qemu-system-x86_64 &>/dev/null \
        || die "qemu-system-x86_64 not found. Install: apt install qemu-system-x86"
    command -v qemu-img &>/dev/null \
        || die "qemu-img not found. Install: apt install qemu-utils"
    [[ -e /dev/kvm ]] \
        || die "/dev/kvm not found. Enable KVM virtualization in your BIOS/UEFI."
    if ! command -v cloud-localds &>/dev/null \
        && ! command -v genisoimage &>/dev/null \
        && ! command -v mkisofs &>/dev/null; then
        die "No ISO creation tool found. Install one of:
  apt install cloud-image-utils   (provides cloud-localds)
  apt install genisoimage         (provides genisoimage)"
    fi
}

vbox_check_deps() {
    command -v VBoxManage &>/dev/null \
        || die "VBoxManage not found. Install VirtualBox: https://www.virtualbox.org/"
    command -v qemu-img &>/dev/null \
        || die "qemu-img not found (needed for image conversion). Install: apt install qemu-utils"
    if ! command -v cloud-localds &>/dev/null \
        && ! command -v genisoimage &>/dev/null \
        && ! command -v mkisofs &>/dev/null; then
        die "No ISO creation tool found. Install: apt install cloud-image-utils"
    fi
}

vmware_check_deps() {
    command -v vmrun &>/dev/null \
        || die "vmrun not found. Install VMware Workstation, Player, or Fusion."

    # Detect provider type by probing
    VMWARE_PROVIDER=""
    local provider
    for provider in ws fusion player; do
        if vmrun -T "$provider" list &>/dev/null 2>&1; then
            VMWARE_PROVIDER="$provider"
            break
        fi
    done

    if [[ -z "$VMWARE_PROVIDER" ]]; then
        # Fallback: detect from installed applications
        if [[ -d "/Applications/VMware Fusion.app" ]]; then
            VMWARE_PROVIDER="fusion"
        elif command -v vmplayer &>/dev/null; then
            VMWARE_PROVIDER="player"
        else
            VMWARE_PROVIDER="ws"
        fi
        warn "Could not probe VMware provider; defaulting to: $VMWARE_PROVIDER"
    fi

    [[ "$VERBOSE" == "true" ]] && info "VMware provider: $VMWARE_PROVIDER"
}

check_deps() {
    case "$BACKEND" in
        docker)     docker_check_deps ;;
        kvm)        kvm_check_deps ;;
        virtualbox) vbox_check_deps ;;
        vmware)     vmware_check_deps ;;
    esac
}

# ── Auth check ────────────────────────────────────────────────────────────────
check_auth() {
    local has_auth=false

    if [[ -f "$HOME/.claude/.credentials.json" ]]; then
        has_auth=true
    fi

    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        has_auth=true
    fi

    if [[ "$has_auth" == "false" ]]; then
        die "No Claude authentication found.
  Option 1 (OAuth): Run 'claude auth login' on the host
  Option 2 (API key): Set ANTHROPIC_API_KEY environment variable"
    fi
}

# ── Docker image ──────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOCKERFILE="$SCRIPT_DIR/Dockerfile"
IMAGE_HASH=""

compute_image_hash() {
    if [[ ! -f "$DOCKERFILE" ]]; then
        die "Dockerfile not found at: $DOCKERFILE"
    fi
    IMAGE_HASH="$(sha256sum "$DOCKERFILE" | cut -c1-12)"
}

docker_ensure_image() {
    compute_image_hash
    local image_tag="cvm:${IMAGE_HASH}"

    if [[ "$FORCE_BUILD" == "false" ]] && docker image inspect "$image_tag" &>/dev/null; then
        [[ "$VERBOSE" == "true" ]] && info "Using cached image: $image_tag"
        return 0
    fi

    info "Building Docker image $image_tag..."

    local build_args=(
        build
        -t "$image_tag"
        -f "$DOCKERFILE"
        "$SCRIPT_DIR"
    )

    if [[ "$VERBOSE" == "true" ]]; then
        docker "${build_args[@]}" || die "Docker image build failed."
    else
        docker "${build_args[@]}" &>/dev/null \
            || die "Docker image build failed. Run with -v for details."
    fi

    success "Image built: $image_tag"
}

# ── VM shared utilities ───────────────────────────────────────────────────────
vm_cache_dir="$HOME/.cache/cvm"
VM_BASE_IMAGE_URL="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"

vm_ensure_ssh_key() {
    local key_dir="$vm_cache_dir/ssh"
    mkdir -p "$key_dir"
    chmod 700 "$key_dir"
    if [[ ! -f "$key_dir/id_rsa" ]]; then
        info "Generating VM SSH keypair..."
        ssh-keygen -t rsa -b 4096 -f "$key_dir/id_rsa" -N "" -C "cvm" &>/dev/null
        chmod 600 "$key_dir/id_rsa"
        chmod 644 "$key_dir/id_rsa.pub"
    fi
}

vm_get_install_hash() {
    # Hash the install commands to produce a content-addressed prepared-image tag.
    # Update this string whenever the cloud-init runcmd block changes.
    printf '%s\n' \
        'curl -fsSL https://deb.nodesource.com/setup_20.x | bash -' \
        'apt-get install -y nodejs open-vm-tools' \
        'npm install -g @anthropic-ai/claude-code' \
        'mkdir -p /workspace && chown ubuntu:ubuntu /workspace' \
        | sha256sum | cut -c1-12
}

vm_download_base_image() {
    local images_dir="$vm_cache_dir/images"
    mkdir -p "$images_dir"

    local base_img="$images_dir/base.img"
    if [[ -f "$base_img" ]]; then
        [[ "$VERBOSE" == "true" ]] && info "Using cached base image: $base_img"
        return 0
    fi

    info "Downloading Ubuntu 24.04 cloud image (~600MB, once)..."
    if command -v wget &>/dev/null; then
        wget -q --show-progress -O "$base_img.tmp" "$VM_BASE_IMAGE_URL" \
            || die "Failed to download base image"
    elif command -v curl &>/dev/null; then
        curl -L --progress-bar -o "$base_img.tmp" "$VM_BASE_IMAGE_URL" \
            || die "Failed to download base image"
    else
        die "Neither wget nor curl found; cannot download base image"
    fi

    mv "$base_img.tmp" "$base_img"
    success "Base image downloaded: $base_img"
}

vm_make_seed_iso() {
    local seed_iso="$1"
    local user_data="$2"
    local meta_data="$3"
    local workdir
    workdir="$(mktemp -d /tmp/cvm-cloudinit-XXXXXX)"
    cp "$user_data" "$workdir/user-data"
    cp "$meta_data" "$workdir/meta-data"

    if command -v cloud-localds &>/dev/null; then
        cloud-localds "$seed_iso" "$workdir/user-data" "$workdir/meta-data" \
            || die "cloud-localds failed to create seed ISO"
    elif command -v genisoimage &>/dev/null; then
        genisoimage -output "$seed_iso" -volid cidata -joliet -rock \
            "$workdir/user-data" "$workdir/meta-data" &>/dev/null \
            || die "genisoimage failed to create seed ISO"
    elif command -v mkisofs &>/dev/null; then
        mkisofs -output "$seed_iso" -volid cidata -joliet -rock \
            "$workdir/user-data" "$workdir/meta-data" &>/dev/null \
            || die "mkisofs failed to create seed ISO"
    else
        die "No ISO creation tool found (need cloud-localds, genisoimage, or mkisofs)"
    fi

    rm -rf "$workdir"
}

vm_write_user_data() {
    local outfile="$1"
    local pubkey
    pubkey="$(cat "$vm_cache_dir/ssh/id_rsa.pub")"

    cat > "$outfile" <<USERDATA
#cloud-config
users:
  - name: ubuntu
    ssh_authorized_keys:
      - ${pubkey}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
packages:
  - curl
package_update: true
runcmd:
  - curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  - apt-get install -y nodejs open-vm-tools
  - npm install -g @anthropic-ai/claude-code
  - mkdir -p /workspace && chown ubuntu:ubuntu /workspace
USERDATA
}

vm_write_meta_data() {
    local outfile="$1"
    local instance_id="${2:-cvm-prepare}"
    cat > "$outfile" <<METADATA
instance-id: ${instance_id}
local-hostname: cvm
METADATA
}

vm_wait_for_ssh() {
    local host="$1" port="$2"
    local timeout=180
    local elapsed=0

    info "Waiting for SSH on $host:$port..."
    while [[ $elapsed -lt $timeout ]]; do
        if ssh \
            -o StrictHostKeyChecking=no \
            -o UserKnownHostsFile=/dev/null \
            -o ConnectTimeout=3 \
            -o BatchMode=yes \
            -i "$vm_cache_dir/ssh/id_rsa" \
            -p "$port" \
            "ubuntu@$host" true &>/dev/null 2>&1; then
            return 0
        fi
        sleep 3
        elapsed=$((elapsed + 3))
    done
    die "Timed out waiting for SSH on $host:$port after ${timeout}s"
}

vm_wait_for_cloud_init() {
    local host="$1" port="$2"
    local timeout=600
    local elapsed=0

    info "Waiting for cloud-init to finish..."
    while [[ $elapsed -lt $timeout ]]; do
        local status
        status="$(ssh \
            -o StrictHostKeyChecking=no \
            -o UserKnownHostsFile=/dev/null \
            -o ConnectTimeout=5 \
            -o BatchMode=yes \
            -i "$vm_cache_dir/ssh/id_rsa" \
            -p "$port" \
            "ubuntu@$host" \
            'cloud-init status 2>/dev/null || echo unknown' 2>/dev/null || echo unknown)"
        if [[ "$status" == *"done"* ]]; then
            return 0
        fi
        sleep 10
        elapsed=$((elapsed + 10))
    done
    die "Timed out waiting for cloud-init after ${timeout}s"
}

vm_setup_claude_auth() {
    local host="$1" port="$2"
    local ssh_base="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes -i $vm_cache_dir/ssh/id_rsa"

    ssh $ssh_base -p "$port" "ubuntu@$host" "mkdir -p /home/ubuntu/.claude" &>/dev/null

    if [[ -f "$HOME/.claude/.credentials.json" ]]; then
        scp $ssh_base -P "$port" \
            "$HOME/.claude/.credentials.json" \
            "ubuntu@$host:/home/ubuntu/.claude/.credentials.json" &>/dev/null
    fi
    if [[ -f "$HOME/.claude/settings.json" ]]; then
        scp $ssh_base -P "$port" \
            "$HOME/.claude/settings.json" \
            "ubuntu@$host:/home/ubuntu/.claude/settings.json" &>/dev/null
    fi
    if [[ -f "$HOME/.claude.json" ]]; then
        scp $ssh_base -P "$port" \
            "$HOME/.claude.json" \
            "ubuntu@$host:/home/ubuntu/.claude.json" &>/dev/null
    fi
}

vm_copy_workspace_in() {
    local host="$1" port="$2"
    local ssh_base="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes -i $vm_cache_dir/ssh/id_rsa"

    ssh $ssh_base -p "$port" "ubuntu@$host" "mkdir -p /workspace" &>/dev/null

    if [[ -n "$(ls -A "$WORKSPACE" 2>/dev/null)" ]]; then
        scp $ssh_base -P "$port" -r "$WORKSPACE/." "ubuntu@$host:/workspace/" &>/dev/null
    fi
}

vm_run_claude_ssh() {
    local host="$1" port="$2"
    local ssh_base="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes -i $vm_cache_dir/ssh/id_rsa"

    # Copy task to VM to safely handle special characters
    local task_file
    task_file="$(mktemp /tmp/cvm-task-XXXXXX.txt)"
    printf '%s' "$TASK" > "$task_file"
    scp $ssh_base -P "$port" "$task_file" "ubuntu@$host:/tmp/cvm-task.txt" &>/dev/null
    rm -f "$task_file"

    # Build API key export prefix for non-interactive SSH shells
    local api_prefix=""
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        api_prefix="export ANTHROPIC_API_KEY=$(printf '%q' "$ANTHROPIC_API_KEY"); "
    fi

    # Remote command: $(cat /tmp/cvm-task.txt) is expanded by the remote shell
    local remote_cmd
    remote_cmd="${api_prefix}cd /workspace && claude --dangerously-skip-permissions --no-session-persistence -p \"\$(cat /tmp/cvm-task.txt)\" --model $MODEL"
    [[ -n "$BUDGET" ]] && remote_cmd="$remote_cmd --max-budget-usd $BUDGET"

    if [[ "$VERBOSE" == "true" ]]; then
        remote_cmd="$remote_cmd --output-format stream-json --verbose"
        write_stream_json_parser
        # shellcheck disable=SC2086
        ssh $ssh_base -p "$port" "ubuntu@$host" "$remote_cmd" | parse_stream_json
        return ${PIPESTATUS[0]}
    else
        # shellcheck disable=SC2086
        ssh $ssh_base -p "$port" "ubuntu@$host" "$remote_cmd"
        return $?
    fi
}

vm_copy_workspace_out() {
    local host="$1" port="$2"
    local ssh_base="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes -i $vm_cache_dir/ssh/id_rsa"
    scp $ssh_base -P "$port" -r "ubuntu@$host:/workspace/." "$WORKSPACE/" &>/dev/null || true
}

vm_random_port() {
    echo $((10000 + RANDOM % 50000))
}

# ── KVM backend ───────────────────────────────────────────────────────────────
kvm_ensure_image() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_img="$vm_cache_dir/images/kvm-prepared-${install_hash}.qcow2"

    if [[ "$FORCE_BUILD" == "false" ]] && [[ -f "$prepared_img" ]]; then
        [[ "$VERBOSE" == "true" ]] && info "Using cached KVM image: $prepared_img"
        return 0
    fi

    vm_ensure_ssh_key
    vm_download_base_image

    local base_img="$vm_cache_dir/images/base.img"
    local build_dir
    build_dir="$(mktemp -d /tmp/cvm-kvm-build-XXXXXX)"
    local build_port
    build_port="$(vm_random_port)"

    info "Preparing KVM image (installing claude-code, ~5 min)..."

    # Create overlay on base image
    qemu-img create -f qcow2 -b "$base_img" -F qcow2 "$build_dir/build-overlay.qcow2" \
        &>/dev/null || die "qemu-img create failed"

    # Create cloud-init seed ISO
    vm_write_user_data "$build_dir/user-data"
    vm_write_meta_data "$build_dir/meta-data" "cvm-kvm-prepare"
    vm_make_seed_iso "$build_dir/seed.iso" "$build_dir/user-data" "$build_dir/meta-data"

    # Boot VM to run cloud-init
    local qemu_pid
    qemu-system-x86_64 \
        -enable-kvm \
        -m 2048 \
        -smp 2 \
        -nographic \
        -serial none \
        -monitor none \
        -drive "file=$build_dir/build-overlay.qcow2,format=qcow2" \
        -drive "file=$build_dir/seed.iso,format=raw,readonly=on,if=virtio" \
        -netdev "user,id=net0,hostfwd=tcp::${build_port}-:22" \
        -device virtio-net-pci,netdev=net0 \
        &>/dev/null &
    qemu_pid=$!

    # Ensure qemu is cleaned up if we die
    local cleanup_qemu="kill $qemu_pid 2>/dev/null; wait $qemu_pid 2>/dev/null; rm -rf $build_dir"

    vm_wait_for_ssh localhost "$build_port" \
        || { eval "$cleanup_qemu"; die "SSH timeout during KVM image prepare"; }

    vm_wait_for_cloud_init localhost "$build_port" \
        || { eval "$cleanup_qemu"; die "cloud-init timeout during KVM image prepare"; }

    # Graceful shutdown
    ssh \
        -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
        -o BatchMode=yes -o ConnectTimeout=5 \
        -i "$vm_cache_dir/ssh/id_rsa" \
        -p "$build_port" \
        ubuntu@localhost "sudo shutdown -h now" &>/dev/null || true
    wait "$qemu_pid" 2>/dev/null || true

    # Save prepared image
    mv "$build_dir/build-overlay.qcow2" "$prepared_img"
    rm -rf "$build_dir"
    success "KVM image prepared: $prepared_img"
}

kvm_run_claude() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_img="$vm_cache_dir/images/kvm-prepared-${install_hash}.qcow2"

    VM_PORT="$(vm_random_port)"
    local task_dir
    task_dir="$(mktemp -d /tmp/cvm-kvm-task-XXXXXX)"

    # Create task overlay on prepared image
    qemu-img create -f qcow2 -b "$prepared_img" -F qcow2 "$task_dir/task-overlay.qcow2" \
        &>/dev/null || die "qemu-img create task overlay failed"

    info "Starting KVM VM (SSH port $VM_PORT)..."
    qemu-system-x86_64 \
        -enable-kvm \
        -m 2048 \
        -smp 2 \
        -nographic \
        -serial none \
        -monitor none \
        -drive "file=$task_dir/task-overlay.qcow2,format=qcow2" \
        -netdev "user,id=net0,hostfwd=tcp::${VM_PORT}-:22" \
        -device virtio-net-pci,netdev=net0 \
        &>/dev/null &
    VM_PID=$!

    vm_wait_for_ssh localhost "$VM_PORT"
    vm_setup_claude_auth localhost "$VM_PORT"
    vm_copy_workspace_in localhost "$VM_PORT"

    echo ""
    info "Task: ${BOLD}${TASK}${RESET}"
    info "Model: $MODEL"
    [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
    echo ""

    local exit_code=0
    vm_run_claude_ssh localhost "$VM_PORT" || exit_code=$?

    vm_copy_workspace_out localhost "$VM_PORT"

    # Graceful shutdown
    ssh \
        -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
        -o BatchMode=yes -o ConnectTimeout=5 \
        -i "$vm_cache_dir/ssh/id_rsa" \
        -p "$VM_PORT" \
        ubuntu@localhost "sudo shutdown -h now" &>/dev/null || true
    wait "$VM_PID" 2>/dev/null || true
    VM_PID=""

    if [[ "$KEEP" == "true" ]]; then
        info "Task overlay kept at: $task_dir"
    else
        rm -rf "$task_dir"
    fi

    if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
        echo ""
        warn "Claude exited with code $exit_code"
    fi

    show_file_summary
    return $exit_code
}

# ── VirtualBox backend ────────────────────────────────────────────────────────
# Fixed MAC for all cvm VirtualBox VMs. Cloud-init writes a MAC-specific netplan
# config; using the same MAC on both the prepared VM and every task clone ensures
# the guest always gets a DHCP lease from VirtualBox NAT.
VBOX_CVM_MAC="080027434D56"

vbox_reload_config() {
    # VBoxSVC caches VM configs in memory after --register.  Direct edits to the
    # .vbox file are ignored until we unregister and re-register so VBoxSVC re-reads.
    local vm_name="$1"
    local vbox_file
    vbox_file="$(VBoxManage showvminfo "$vm_name" --machinereadable 2>/dev/null \
        | grep '^CfgFile=' | cut -d'"' -f2)"
    [[ -z "$vbox_file" ]] && die "Could not locate .vbox file for VM: $vm_name"
    VBoxManage unregistervm "$vm_name" &>/dev/null || true
    VBoxManage registervm "$vbox_file" &>/dev/null \
        || die "Failed to re-register VM after config patch: $vm_name"
}

vbox_set_nat_forwarding() {
    # VBoxManage 7.2.x has a bug where --natpf1 on a linked clone writes
    # hostport=0 to the .vbox XML.  Work around it by patching the XML directly,
    # then forcing VBoxSVC to reload the config via unregister+re-register.
    #
    # Uses Python (not sed) because the NAT section spans multiple lines in the
    # .vbox XML, so single-line sed patterns cannot match it reliably.
    # Handles two cases:
    #   1. <Forwarding name="ssh" .../> already present → update hostport in-place
    #   2. <NAT .../> is self-closing (no Forwarding) → expand with new Forwarding
    local vm_name="$1" port="$2"
    local vbox_file
    vbox_file="$(VBoxManage showvminfo "$vm_name" --machinereadable 2>/dev/null \
        | grep '^CfgFile=' | cut -d'"' -f2)"
    [[ -z "$vbox_file" ]] && die "Could not locate .vbox file for VM: $vm_name"

    local pyfile
    pyfile="$(mktemp /tmp/cvm-vboxpatch-XXXXXX.py)"
    cat > "$pyfile" << 'PYEOF'
import sys, re
vbox_file, port = sys.argv[1], sys.argv[2]
forwarding = '<Forwarding name="ssh" proto="1" hostport="{}" guestport="22"/>'.format(port)
with open(vbox_file, 'r') as f:
    content = f.read()
if re.search(r'<Forwarding\s+name="ssh"', content):
    # Case 1: update existing ssh Forwarding element
    content = re.sub(r'<Forwarding\s+name="ssh"[^/]*/>', forwarding, content)
else:
    # Case 2: expand self-closing <NAT attrs/> to include Forwarding
    content = re.sub(
        r'(<NAT\b[^>]*)/>',
        lambda m: '{}>  {}\n            </NAT>'.format(m.group(1), forwarding),
        content)
with open(vbox_file, 'w') as f:
    f.write(content)
PYEOF
    python3 "$pyfile" "$vbox_file" "$port"
    local rc=$?
    rm -f "$pyfile"
    [[ $rc -eq 0 ]] || die "Python XML patch failed for: $vm_name"

    grep -q "hostport=\"${port}\"" "$vbox_file" \
        || die "Failed to patch NAT port forwarding in $vbox_file"

    vbox_reload_config "$vm_name"
}

vbox_ensure_image() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_vm="cvm-prepared-${install_hash}"
    local images_dir="$vm_cache_dir/images"
    local prepared_vdi="$images_dir/vbox-prepared-${install_hash}.vdi"

    # Check if prepared VM exists with "ready" snapshot
    if [[ "$FORCE_BUILD" == "false" ]] \
        && VBoxManage showvminfo "$prepared_vm" &>/dev/null 2>&1 \
        && VBoxManage snapshot "$prepared_vm" list 2>/dev/null | grep -q "ready"; then
        [[ "$VERBOSE" == "true" ]] && info "Using cached VirtualBox VM: $prepared_vm"
        return 0
    fi

    vm_ensure_ssh_key
    vm_download_base_image

    local base_img="$vm_cache_dir/images/base.img"
    info "Preparing VirtualBox image (installing claude-code, ~5 min)..."

    # Remove old prepared VM if it exists
    if VBoxManage showvminfo "$prepared_vm" &>/dev/null 2>&1; then
        VBoxManage controlvm "$prepared_vm" poweroff &>/dev/null || true
        sleep 2
        VBoxManage unregistervm "$prepared_vm" --delete &>/dev/null || true
    fi
    # Also remove stale VDI file if VirtualBox didn't clean it
    if VBoxManage list hdds 2>/dev/null | grep -q "$prepared_vdi"; then
        VBoxManage closemedium disk "$prepared_vdi" --delete &>/dev/null || true
    fi
    rm -f "$prepared_vdi"

    # Convert base image to a per-hash VDI
    info "Converting base image to VDI format..."
    qemu-img convert -f qcow2 -O vdi "$base_img" "$prepared_vdi" \
        || die "qemu-img convert to VDI failed"

    local build_port
    build_port="$(vm_random_port)"
    local build_dir
    build_dir="$(mktemp -d /tmp/cvm-vbox-build-XXXXXX)"

    # Create and configure VM; use VBOX_CVM_MAC so cloud-init's netplan config
    # (which is MAC-specific) matches every future task clone.
    VBoxManage createvm --name "$prepared_vm" --ostype Ubuntu_64 --register \
        || die "VBoxManage createvm failed"
    VBoxManage modifyvm "$prepared_vm" \
        --memory 2048 --cpus 2 \
        --nic1 nat \
        --macaddress1 "$VBOX_CVM_MAC" \
        --boot1 disk --boot2 dvd \
        || die "VBoxManage modifyvm failed"

    # Set SSH port forwarding via XML patch (VBoxManage 7.2 --natpf1 bug workaround)
    vbox_set_nat_forwarding "$prepared_vm" "$build_port"

    # Add storage controllers
    VBoxManage storagectl "$prepared_vm" --name "SATA" --add sata --controller IntelAhci
    VBoxManage storagectl "$prepared_vm" --name "IDE" --add ide

    # Attach VDI
    VBoxManage storageattach "$prepared_vm" \
        --storagectl "SATA" --port 0 --device 0 --type hdd \
        --medium "$prepared_vdi" \
        || die "Failed to attach VDI"

    # Create cloud-init seed ISO
    vm_write_user_data "$build_dir/user-data"
    vm_write_meta_data "$build_dir/meta-data" "cvm-vbox-prepare"
    vm_make_seed_iso "$build_dir/seed.iso" "$build_dir/user-data" "$build_dir/meta-data"

    VBoxManage storageattach "$prepared_vm" \
        --storagectl "IDE" --port 0 --device 0 --type dvddrive \
        --medium "$build_dir/seed.iso" \
        || die "Failed to attach seed ISO"

    # Start VM
    VBoxManage startvm "$prepared_vm" --type headless \
        || die "VBoxManage startvm failed"

    vm_wait_for_ssh localhost "$build_port" \
        || { VBoxManage controlvm "$prepared_vm" poweroff &>/dev/null || true
             VBoxManage unregistervm "$prepared_vm" --delete &>/dev/null || true
             rm -rf "$build_dir"; die "SSH timeout during VirtualBox image prepare"; }

    vm_wait_for_cloud_init localhost "$build_port" \
        || { VBoxManage controlvm "$prepared_vm" poweroff &>/dev/null || true
             VBoxManage unregistervm "$prepared_vm" --delete &>/dev/null || true
             rm -rf "$build_dir"; die "cloud-init timeout during VirtualBox image prepare"; }

    # Graceful shutdown
    ssh \
        -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
        -o BatchMode=yes -o ConnectTimeout=5 \
        -i "$vm_cache_dir/ssh/id_rsa" \
        -p "$build_port" \
        ubuntu@localhost "sudo shutdown -h now" &>/dev/null || true
    sleep 8  # wait for VirtualBox to complete shutdown

    # Remove port forwarding from .vbox before snapshot; task clones add their own.
    # Uses Python (not sed) because the NAT+Forwarding section spans multiple lines.
    local vbox_file
    vbox_file="$(VBoxManage showvminfo "$prepared_vm" --machinereadable 2>/dev/null \
        | grep '^CfgFile=' | cut -d'"' -f2)"
    local pyfile
    pyfile="$(mktemp /tmp/cvm-vboxpatch-XXXXXX.py)"
    cat > "$pyfile" << 'PYEOF'
import sys, re
vbox_file = sys.argv[1]
with open(vbox_file, 'r') as f:
    content = f.read()
# Remove all Forwarding elements inside NAT
content = re.sub(r'\s*<Forwarding[^/]*/>', '', content)
# Collapse empty <NAT attrs></NAT> back to self-closing <NAT attrs/>
content = re.sub(r'<NAT([^>]*)>\s*</NAT>', r'<NAT\1/>', content)
with open(vbox_file, 'w') as f:
    f.write(content)
PYEOF
    python3 "$pyfile" "$vbox_file"
    local rc=$?
    rm -f "$pyfile"
    [[ $rc -eq 0 ]] || die "Python XML patch (clear forwarding) failed"
    vbox_reload_config "$prepared_vm"

    # Detach seed ISO
    VBoxManage storageattach "$prepared_vm" \
        --storagectl "IDE" --port 0 --device 0 --type dvddrive \
        --medium none &>/dev/null || true

    # Take snapshot
    VBoxManage snapshot "$prepared_vm" take ready \
        || die "VBoxManage snapshot take ready failed"

    rm -rf "$build_dir"
    success "VirtualBox VM prepared: $prepared_vm (snapshot: ready)"
}

vbox_run_claude() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_vm="cvm-prepared-${install_hash}"

    VM_NAME="cvm-task-$$"
    VM_PORT="$(vm_random_port)"

    info "Cloning VirtualBox VM for task (linked clone)..."
    VBoxManage clonevm "$prepared_vm" \
        --snapshot ready \
        --name "$VM_NAME" \
        --register \
        --options link \
        || die "VBoxManage clonevm failed"

    # Set fixed MAC so cloud-init's netplan config (which is MAC-specific) applies.
    VBoxManage modifyvm "$VM_NAME" --macaddress1 "$VBOX_CVM_MAC" \
        || die "VBoxManage modifyvm (macaddress) failed"

    VBoxManage startvm "$VM_NAME" --type headless \
        || die "VBoxManage startvm failed"

    # Add SSH port forwarding via controlvm (not modifyvm) to avoid VBoxManage 7.2.x
    # bug where --natpf1 on an offline linked clone writes hostport=0 to the .vbox
    # XML.  controlvm natpf1 operates on the running hypervisor and is not affected.
    VBoxManage controlvm "$VM_NAME" natpf1 "ssh,tcp,,${VM_PORT},,22" \
        || die "VBoxManage controlvm natpf1 failed"

    vm_wait_for_ssh localhost "$VM_PORT"
    vm_setup_claude_auth localhost "$VM_PORT"
    vm_copy_workspace_in localhost "$VM_PORT"

    echo ""
    info "Task: ${BOLD}${TASK}${RESET}"
    info "Model: $MODEL"
    [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
    echo ""

    local exit_code=0
    vm_run_claude_ssh localhost "$VM_PORT" || exit_code=$?

    vm_copy_workspace_out localhost "$VM_PORT"

    # Stop and delete task VM
    VBoxManage controlvm "$VM_NAME" poweroff &>/dev/null || true
    sleep 2
    VBoxManage unregistervm "$VM_NAME" --delete &>/dev/null || true
    VM_NAME=""

    if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
        echo ""
        warn "Claude exited with code $exit_code"
    fi

    show_file_summary
    return $exit_code
}

# ── VMware backend ────────────────────────────────────────────────────────────
vmware_write_vmx() {
    local vmx_file="$1"
    local vmdk_name="$2"
    local cdrom_iso="$3"  # empty = no cdrom
    local memory="$4"

    cat > "$vmx_file" <<VMXEOF
.encoding = "UTF-8"
config.version = "8"
virtualHW.version = "19"
memsize = "${memory}"
numvcpus = "2"
guestOS = "ubuntu-64"
displayName = "cvm"
scsi0.present = "TRUE"
scsi0.virtualDev = "pvscsi"
scsi0:0.present = "TRUE"
scsi0:0.fileName = "${vmdk_name}"
scsi0:0.deviceType = "disk"
ethernet0.present = "TRUE"
ethernet0.connectionType = "nat"
ethernet0.virtualDev = "vmxnet3"
ethernet0.addressType = "generated"
usb.present = "FALSE"
sound.present = "FALSE"
tools.syncTime = "FALSE"
vmci0.present = "FALSE"
VMXEOF

    if [[ -n "$cdrom_iso" ]]; then
        cat >> "$vmx_file" <<CDROM
ide1:0.present = "TRUE"
ide1:0.fileName = "${cdrom_iso}"
ide1:0.deviceType = "cdrom-image"
CDROM
    fi
}

vmware_get_guest_ip() {
    local vmx_file="$1"
    local timeout=120
    local elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        local ip
        ip="$(vmrun -T "$VMWARE_PROVIDER" getGuestIPAddress "$vmx_file" -wait 2>/dev/null || true)"
        if [[ -n "$ip" ]] && [[ "$ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "$ip"
            return 0
        fi
        sleep 5
        elapsed=$((elapsed + 5))
    done
    return 1
}

vmware_ensure_image() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_dir="$vm_cache_dir/images/vmware-prepared-${install_hash}"
    local vmx_file="$prepared_dir/ubuntu.vmx"

    if [[ "$FORCE_BUILD" == "false" ]] \
        && [[ -f "$vmx_file" ]] \
        && vmrun -T "$VMWARE_PROVIDER" listSnapshots "$vmx_file" 2>/dev/null | grep -q "ready"; then
        [[ "$VERBOSE" == "true" ]] && info "Using cached VMware image: $prepared_dir"
        return 0
    fi

    vm_ensure_ssh_key
    vm_download_base_image

    local base_img="$vm_cache_dir/images/base.img"
    info "Preparing VMware image (installing claude-code, ~5 min)..."

    # Remove old prepared dir if exists
    if [[ -d "$prepared_dir" ]]; then
        vmrun -T "$VMWARE_PROVIDER" stop "$vmx_file" hard &>/dev/null || true
        rm -rf "$prepared_dir"
    fi
    mkdir -p "$prepared_dir"

    # Convert base image to VMDK
    info "Converting base image to VMDK format..."
    qemu-img convert -f qcow2 -O vmdk "$base_img" "$prepared_dir/ubuntu.vmdk" \
        || die "qemu-img convert to VMDK failed"

    # Create cloud-init seed ISO
    vm_write_user_data "$prepared_dir/user-data"
    vm_write_meta_data "$prepared_dir/meta-data" "cvm-vmware-prepare"
    vm_make_seed_iso "$prepared_dir/seed.iso" \
        "$prepared_dir/user-data" "$prepared_dir/meta-data"

    # Write VMX with cdrom attached for cloud-init
    vmware_write_vmx "$vmx_file" "ubuntu.vmdk" "seed.iso" 2048

    # Start VM
    vmrun -T "$VMWARE_PROVIDER" start "$vmx_file" nogui \
        || die "vmrun start failed"

    # Get guest IP (requires open-vm-tools in guest)
    info "Getting VM IP address..."
    local vm_ip
    vm_ip="$(vmware_get_guest_ip "$vmx_file")" \
        || { vmrun -T "$VMWARE_PROVIDER" stop "$vmx_file" hard &>/dev/null || true
             die "Could not get VMware guest IP address (is open-vm-tools installed?)"; }

    vm_wait_for_ssh "$vm_ip" 22 \
        || { vmrun -T "$VMWARE_PROVIDER" stop "$vmx_file" hard &>/dev/null || true
             die "SSH timeout during VMware image prepare"; }

    vm_wait_for_cloud_init "$vm_ip" 22 \
        || { vmrun -T "$VMWARE_PROVIDER" stop "$vmx_file" hard &>/dev/null || true
             die "cloud-init timeout during VMware image prepare"; }

    # Graceful shutdown
    ssh \
        -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
        -o BatchMode=yes -o ConnectTimeout=5 \
        -i "$vm_cache_dir/ssh/id_rsa" \
        -p 22 \
        "ubuntu@$vm_ip" "sudo shutdown -h now" &>/dev/null || true
    sleep 10

    # Rewrite VMX without cdrom for clean snapshot
    vmware_write_vmx "$vmx_file" "ubuntu.vmdk" "" 2048

    # Clean up cloud-init temp files
    rm -f "$prepared_dir/user-data" "$prepared_dir/meta-data" "$prepared_dir/seed.iso"

    # Take snapshot
    vmrun -T "$VMWARE_PROVIDER" snapshot "$vmx_file" ready \
        || die "vmrun snapshot failed"

    success "VMware image prepared: $prepared_dir (snapshot: ready)"
}

vmware_run_claude() {
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_dir="$vm_cache_dir/images/vmware-prepared-${install_hash}"
    local prepared_vmx="$prepared_dir/ubuntu.vmx"

    VM_TASK_DIR="$(mktemp -d /tmp/cvm-vmware-task-XXXXXX)"
    VM_NAME="$VM_TASK_DIR/ubuntu.vmx"

    info "Copying VMware image for task..."
    cp -r "$prepared_dir/." "$VM_TASK_DIR/"

    # Write VMX without cdrom for task run
    vmware_write_vmx "$VM_TASK_DIR/ubuntu.vmx" "ubuntu.vmdk" "" 2048

    # Revert to "ready" snapshot (operates on the copy)
    vmrun -T "$VMWARE_PROVIDER" revertToSnapshot "$VM_TASK_DIR/ubuntu.vmx" ready \
        &>/dev/null || true

    # Start task VM
    vmrun -T "$VMWARE_PROVIDER" start "$VM_TASK_DIR/ubuntu.vmx" nogui \
        || die "vmrun start (task) failed"

    # Get guest IP
    info "Getting VM IP address..."
    local vm_ip
    vm_ip="$(vmware_get_guest_ip "$VM_TASK_DIR/ubuntu.vmx")" \
        || die "Could not get VMware guest IP address"

    vm_wait_for_ssh "$vm_ip" 22
    vm_setup_claude_auth "$vm_ip" 22
    vm_copy_workspace_in "$vm_ip" 22

    echo ""
    info "Task: ${BOLD}${TASK}${RESET}"
    info "Model: $MODEL"
    [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
    echo ""

    local exit_code=0
    vm_run_claude_ssh "$vm_ip" 22 || exit_code=$?

    vm_copy_workspace_out "$vm_ip" 22

    # Stop and remove task VM
    vmrun -T "$VMWARE_PROVIDER" stop "$VM_TASK_DIR/ubuntu.vmx" hard &>/dev/null || true
    rm -rf "$VM_TASK_DIR"
    VM_TASK_DIR=""
    VM_NAME=""

    if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
        echo ""
        warn "Claude exited with code $exit_code"
    fi

    show_file_summary
    return $exit_code
}

# ── KVM Named VM operations ───────────────────────────────────────────────────
kvm_vm_create() {
    local name="$1"
    local vm_dir="$CVM_VMS_DIR/$name"
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_img="$vm_cache_dir/images/kvm-prepared-${install_hash}.qcow2"

    mkdir -p "$vm_dir/workspace"

    info "Creating KVM persistent disk for VM '$name'..."
    qemu-img create -f qcow2 -b "$prepared_img" -F qcow2 "$vm_dir/disk.qcow2" \
        &>/dev/null || die "qemu-img create (named VM disk) failed"

    success "KVM VM '$name' created: $vm_dir"
}

kvm_vm_start() {
    local name="$1"
    local disk
    disk="$(registry_get_field "$name" disk)"
    [[ -f "$disk" ]] || die "KVM disk not found: $disk"

    local port
    port="$(vm_random_port)"

    info "Starting KVM VM '$name' (SSH port $port)..."
    qemu-system-x86_64 \
        -enable-kvm \
        -m 2048 \
        -smp 2 \
        -nographic \
        -serial none \
        -monitor none \
        -drive "file=$disk,format=qcow2" \
        -netdev "user,id=net0,hostfwd=tcp::${port}-:22" \
        -device virtio-net-pci,netdev=net0 \
        &>/dev/null &
    local pid=$!
    echo "$pid"  > "/tmp/cvm-${name}.pid"
    echo "$port" > "/tmp/cvm-${name}.port"

    vm_wait_for_ssh localhost "$port" || {
        kill "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
        rm -f "/tmp/cvm-${name}.pid" "/tmp/cvm-${name}.port"
        die "SSH timeout starting KVM VM '$name'"
    }
    success "KVM VM '$name' started (PID $pid, port $port)"
}

kvm_vm_stop() {
    local name="$1"
    local pid_file="/tmp/cvm-${name}.pid"
    local port_file="/tmp/cvm-${name}.port"

    if [[ ! -f "$pid_file" ]]; then
        warn "No PID file found for KVM VM '$name' — may already be stopped"
        return 0
    fi

    local port
    port="$(cat "$port_file" 2>/dev/null || echo "")"

    info "Shutting down KVM VM '$name'..."
    if [[ -n "$port" ]]; then
        ssh \
            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
            -o BatchMode=yes -o ConnectTimeout=5 \
            -i "$vm_cache_dir/ssh/id_rsa" \
            -p "$port" \
            ubuntu@localhost "sudo shutdown -h now" &>/dev/null || true
    fi

    local pid
    pid="$(cat "$pid_file" 2>/dev/null || echo "")"
    if [[ -n "$pid" ]]; then
        local timeout=60 elapsed=0
        while [[ $elapsed -lt $timeout ]]; do
            kill -0 "$pid" 2>/dev/null || break
            sleep 2
            elapsed=$((elapsed + 2))
        done
        kill "$pid" 2>/dev/null || true
    fi

    rm -f "$pid_file" "$port_file"
    success "KVM VM '$name' stopped"
}

kvm_vm_delete() {
    local name="$1"
    local disk workspace
    disk="$(registry_get_field "$name" disk 2>/dev/null || echo "")"
    workspace="$(registry_get_field "$name" workspace 2>/dev/null || echo "")"

    if vm_is_running "$name" kvm; then
        kvm_vm_stop "$name"
    fi

    [[ -n "$disk" ]] && rm -f "$disk"
    if [[ -n "$workspace" ]]; then
        rm -rf "$(dirname "$workspace")"
    fi
}

kvm_vm_rename() {
    local name="$1" new_name="$2"
    if vm_is_running "$name" kvm; then
        die "Cannot rename running KVM VM '$name'. Stop it first with: cvm stop $name"
    fi
    mv "$CVM_VMS_DIR/$name" "$CVM_VMS_DIR/$new_name"
}

kvm_vm_move() {
    local name="$1" dest="$2"
    if vm_is_running "$name" kvm; then
        die "Cannot move running KVM VM '$name'. Stop it first with: cvm stop $name"
    fi
    mkdir -p "$dest"
    mv "$CVM_VMS_DIR/$name" "$dest/$name"
}

# ── VirtualBox Named VM operations ────────────────────────────────────────────
vbox_vm_create() {
    local name="$1"
    local vbox_name="cvm-${name}"
    local install_hash
    install_hash="$(vm_get_install_hash)"
    local prepared_vm="cvm-prepared-${install_hash}"
    local vm_dir="$CVM_VMS_DIR/$name"

    mkdir -p "$vm_dir/workspace"

    info "Creating VirtualBox linked clone for VM '$name'..."
    VBoxManage clonevm "$prepared_vm" \
        --snapshot ready \
        --name "$vbox_name" \
        --register \
        --options link \
        || die "VBoxManage clonevm failed for '$name'"

    VBoxManage modifyvm "$vbox_name" --macaddress1 "$VBOX_CVM_MAC" \
        || die "VBoxManage modifyvm (macaddress) failed for '$name'"

    success "VirtualBox VM '$name' created (VBox name: $vbox_name)"
}

vbox_vm_start() {
    local name="$1"
    local vbox_name="cvm-${name}"
    local port
    port="$(vm_random_port)"

    info "Starting VirtualBox VM '$name' (SSH port $port)..."
    VBoxManage startvm "$vbox_name" --type headless \
        || die "VBoxManage startvm failed for '$name'"

    VBoxManage controlvm "$vbox_name" natpf1 "ssh,tcp,,${port},,22" \
        || die "VBoxManage controlvm natpf1 failed for '$name'"

    echo "$port" > "/tmp/cvm-${name}.port"

    vm_wait_for_ssh localhost "$port" || {
        VBoxManage controlvm "$vbox_name" poweroff &>/dev/null || true
        rm -f "/tmp/cvm-${name}.port"
        die "SSH timeout starting VirtualBox VM '$name'"
    }
    success "VirtualBox VM '$name' started (port $port)"
}

vbox_vm_stop() {
    local name="$1"
    local vbox_name="cvm-${name}"
    local port_file="/tmp/cvm-${name}.port"
    local port
    port="$(cat "$port_file" 2>/dev/null || echo "")"

    info "Shutting down VirtualBox VM '$name'..."
    if [[ -n "$port" ]]; then
        ssh \
            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
            -o BatchMode=yes -o ConnectTimeout=5 \
            -i "$vm_cache_dir/ssh/id_rsa" \
            -p "$port" \
            ubuntu@localhost "sudo shutdown -h now" &>/dev/null || true
    else
        VBoxManage controlvm "$vbox_name" acpipowerbutton &>/dev/null || true
    fi

    local timeout=60 elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        local state
        state="$(VBoxManage showvminfo "$vbox_name" --machinereadable 2>/dev/null \
            | grep '^VMState=' | cut -d'"' -f2 || true)"
        if [[ "$state" == "poweroff" ]] || [[ "$state" == "aborted" ]]; then
            break
        fi
        sleep 2
        elapsed=$((elapsed + 2))
    done

    rm -f "$port_file"
    success "VirtualBox VM '$name' stopped"
}

vbox_vm_delete() {
    local name="$1"
    local vbox_name="cvm-${name}"
    local workspace
    workspace="$(registry_get_field "$name" workspace 2>/dev/null || echo "")"

    if vm_is_running "$name" virtualbox; then
        VBoxManage controlvm "$vbox_name" poweroff &>/dev/null || true
        sleep 2
    fi
    rm -f "/tmp/cvm-${name}.port"

    if VBoxManage showvminfo "$vbox_name" &>/dev/null 2>&1; then
        VBoxManage unregistervm "$vbox_name" --delete &>/dev/null \
            || die "VBoxManage unregistervm failed for '$name'"
    fi

    if [[ -n "$workspace" ]]; then
        rm -rf "$(dirname "$workspace")"
    fi
}

vbox_vm_rename() {
    local name="$1" new_name="$2"
    local vbox_name="cvm-${name}"
    local new_vbox_name="cvm-${new_name}"

    if vm_is_running "$name" virtualbox; then
        die "Cannot rename running VirtualBox VM '$name'. Stop it first with: cvm stop $name"
    fi

    VBoxManage modifyvm "$vbox_name" --name "$new_vbox_name" \
        || die "VBoxManage modifyvm --name failed"
    mv "$CVM_VMS_DIR/$name" "$CVM_VMS_DIR/$new_name"
}

vbox_vm_move() {
    local name="$1" dest="$2"
    if vm_is_running "$name" virtualbox; then
        die "Cannot move running VirtualBox VM '$name'. Stop it first with: cvm stop $name"
    fi
    local vbox_name="cvm-${name}"
    mkdir -p "$dest"
    VBoxManage movevm "$vbox_name" --folder "$dest" &>/dev/null \
        || die "VBoxManage movevm failed for '$name'"
}

# ── Docker Named VM operations ────────────────────────────────────────────────
docker_vm_create() {
    local name="$1"
    local vm_dir="$CVM_VMS_DIR/$name"
    mkdir -p "$vm_dir/workspace"
    chmod 777 "$vm_dir/workspace"
    success "Docker VM '$name' created: $vm_dir"
}

docker_vm_run_claude() {
    local name="$1"
    local workspace
    workspace="$(registry_get_field "$name" workspace)"
    local image_tag="cvm:${IMAGE_HASH}"

    local claude_tmp
    claude_tmp="$(mktemp -d /tmp/cvm-claude-XXXXXX)"
    chmod 777 "$claude_tmp"
    if [[ -f "$HOME/.claude/.credentials.json" ]]; then
        cp "$HOME/.claude/.credentials.json" "$claude_tmp/.credentials.json"
    fi
    if [[ -f "$HOME/.claude/settings.json" ]]; then
        cp "$HOME/.claude/settings.json" "$claude_tmp/settings.json"
    fi

    local docker_args=(
        run --rm
        --name "cvm-named-${name}-$$"
        -v "${workspace}:/workspace"
        -v "$claude_tmp:/home/ubuntu/.claude"
        -e "TERM=xterm-256color"
        -e "HOME=/home/ubuntu"
        -w /workspace
        --network bridge
    )
    if [[ -f "$HOME/.claude.json" ]]; then
        docker_args+=(-v "$HOME/.claude.json:/home/ubuntu/.claude.json:ro")
    fi
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        docker_args+=(-e "ANTHROPIC_API_KEY")
    fi
    docker_args+=("$image_tag")

    local claude_args=(
        claude --dangerously-skip-permissions --no-session-persistence
        -p "$TASK" --model "$MODEL"
    )
    [[ -n "$BUDGET" ]] && claude_args+=(--max-budget-usd "$BUDGET")
    [[ "$VERBOSE" == "true" ]] && claude_args+=(--output-format stream-json --verbose)

    local exit_code=0
    if [[ "$VERBOSE" == "true" ]]; then
        write_stream_json_parser
        docker "${docker_args[@]}" "${claude_args[@]}" | parse_stream_json
        exit_code=${PIPESTATUS[0]}
    else
        docker "${docker_args[@]}" "${claude_args[@]}"
        exit_code=$?
    fi

    rm -rf "$claude_tmp"
    return $exit_code
}

docker_vm_delete() {
    local name="$1"
    rm -rf "$CVM_VMS_DIR/$name"
}

docker_vm_rename() {
    local name="$1" new_name="$2"
    mv "$CVM_VMS_DIR/$name" "$CVM_VMS_DIR/$new_name"
}

docker_vm_move() {
    local name="$1" dest="$2"
    mkdir -p "$dest"
    mv "$CVM_VMS_DIR/$name" "$dest/$name"
}

# ── Image preparation dispatcher ──────────────────────────────────────────────
ensure_image() {
    case "$BACKEND" in
        docker)     docker_ensure_image ;;
        kvm)        kvm_ensure_image ;;
        virtualbox) vbox_ensure_image ;;
        vmware)     vmware_ensure_image ;;
    esac
}

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE=""
CLAUDE_TMP=""

create_workspace() {
    WORKSPACE="$(mktemp -d /tmp/cvm-workspace-XXXXXX)"
    chmod 777 "$WORKSPACE"  # allow container's non-root user to write

    if [[ -n "$DIR" ]]; then
        if [[ ! -d "$DIR" ]]; then
            die "Directory not found: $DIR"
        fi
        cp -r "$DIR/." "$WORKSPACE/"
        chmod -R a+rw "$WORKSPACE"  # ensure container user can read/write copied files
        [[ "$VERBOSE" == "true" ]] && info "Copied $DIR → $WORKSPACE"
    fi

    # Docker only: create a writable temp ~/.claude dir for the container.
    # Claude writes todos/, debug/, history.jsonl, etc. even in --no-session-persistence
    # mode — mounting the host ~/.claude read-only causes EROFS errors.
    # VM backends copy credentials via SSH in vm_setup_claude_auth() instead.
    if [[ "$BACKEND" == "docker" ]]; then
        CLAUDE_TMP="$(mktemp -d /tmp/cvm-claude-XXXXXX)"
        chmod 777 "$CLAUDE_TMP"
        if [[ -f "$HOME/.claude/.credentials.json" ]]; then
            cp "$HOME/.claude/.credentials.json" "$CLAUDE_TMP/.credentials.json"
        fi
        if [[ -f "$HOME/.claude/settings.json" ]]; then
            cp "$HOME/.claude/settings.json" "$CLAUDE_TMP/settings.json"
        fi
    fi
}

# ── Subcommand implementations ────────────────────────────────────────────────

validate_vm_name() {
    local name="$1"
    [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]] \
        || die "Invalid VM name '$name'. Use only letters, digits, hyphens, underscores (must start with letter/digit)."
}

# cvm spinup [--name NAME] [--backend BACKEND]
cmd_spinup() {
    local name="" spinup_backend=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)    [[ $# -lt 2 ]] && die "--name requires an argument"; name="$2"; shift 2 ;;
            --backend) [[ $# -lt 2 ]] && die "--backend requires an argument"; spinup_backend="$2"; shift 2 ;;
            -h|--help) show_help; exit 0 ;;
            *) die "Unknown option for spinup: $1" ;;
        esac
    done

    if [[ -z "$name" ]]; then
        name="vm-$(date +%s)"
    fi
    validate_vm_name "$name"

    if [[ -n "$spinup_backend" ]]; then
        BACKEND="$spinup_backend"
    fi

    setup_colors
    registry_ensure

    if registry_exists "$name"; then
        die "VM '$name' already exists. Use 'cvm list' to see all VMs."
    fi

    detect_backend
    case "$BACKEND" in
        docker|kvm|virtualbox) ;;
        vmware) die "VMware does not support named VMs. Use docker, kvm, or virtualbox." ;;
        *) die "Unknown backend: $BACKEND" ;;
    esac

    check_deps
    check_auth
    info "Provisioning VM '$name' (backend: $BACKEND)..."
    ensure_image

    local created_at
    created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local vm_dir="$CVM_VMS_DIR/$name"

    case "$BACKEND" in
        kvm)
            kvm_vm_create "$name"
            registry_set "$name" \
                "{\"name\":\"$name\",\"backend\":\"kvm\",\"created\":\"$created_at\",\"disk\":\"$vm_dir/disk.qcow2\",\"workspace\":\"$vm_dir/workspace\"}"
            ;;
        virtualbox)
            vbox_vm_create "$name"
            registry_set "$name" \
                "{\"name\":\"$name\",\"backend\":\"virtualbox\",\"created\":\"$created_at\",\"vbox_name\":\"cvm-$name\",\"workspace\":\"$vm_dir/workspace\"}"
            ;;
        docker)
            docker_vm_create "$name"
            registry_set "$name" \
                "{\"name\":\"$name\",\"backend\":\"docker\",\"created\":\"$created_at\",\"workspace\":\"$vm_dir/workspace\"}"
            ;;
    esac

    success "VM '$name' ready. Run tasks with: cvm run $name \"your task\""
}

# cvm list
cmd_list() {
    setup_colors
    registry_ensure

    local vm_list
    mapfile -t vm_list < <(python3 - "$CVM_REGISTRY" <<'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    for vm in data.values():
        name     = vm.get('name', '')
        backend  = vm.get('backend', '')
        created  = vm.get('created', '')[:10]
        location = vm.get('workspace', vm.get('disk', ''))
        print(f"{name}\t{backend}\t{created}\t{location}")
except Exception:
    pass
PYEOF
    )

    if [[ ${#vm_list[@]} -eq 0 ]]; then
        info "No named VMs found. Create one with: cvm spinup --name myvm"
        return 0
    fi

    printf "${BOLD}%-20s %-12s %-12s %-11s %s${RESET}\n" \
        "NAME" "BACKEND" "STATUS" "CREATED" "LOCATION"

    for entry in "${vm_list[@]}"; do
        IFS=$'\t' read -r name backend created location <<< "$entry"
        local status="stopped"
        case "$backend" in
            kvm)        vm_is_running "$name" kvm        && status="running" || true ;;
            virtualbox) vm_is_running "$name" virtualbox && status="running" || true ;;
            docker)     status="ready" ;;
        esac
        local status_color="$DIM"
        [[ "$status" == "running" ]] && status_color="$GREEN"
        [[ "$status" == "ready"   ]] && status_color="$CYAN"
        printf "%-20s %-12s ${status_color}%-12s${RESET} %-11s %s\n" \
            "$name" "$backend" "$status" "$created" "$location"
    done
}

# cvm status <name>
cmd_status() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: cvm status <name>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found. Use 'cvm list' to see all VMs."

    local backend created workspace disk vbox_name
    backend="$(registry_get_field   "$name" backend)"
    created="$(registry_get_field   "$name" created  2>/dev/null || echo "")"
    workspace="$(registry_get_field "$name" workspace 2>/dev/null || echo "")"
    disk="$(registry_get_field      "$name" disk      2>/dev/null || echo "")"
    vbox_name="$(registry_get_field "$name" vbox_name 2>/dev/null || echo "")"

    local status="stopped"
    case "$backend" in
        kvm)        vm_is_running "$name" kvm        && status="running" || true ;;
        virtualbox) vm_is_running "$name" virtualbox && status="running" || true ;;
        docker)     status="ready" ;;
    esac

    echo ""
    echo "${BOLD}VM: $name${RESET}"
    echo "  Backend:   $backend"
    echo "  Status:    $status"
    echo "  Created:   $created"
    [[ -n "$workspace"  ]] && echo "  Workspace: $workspace"
    [[ -n "$disk"       ]] && echo "  Disk:      $disk"
    [[ -n "$vbox_name"  ]] && echo "  VBox name: $vbox_name"
    if [[ "$status" == "running" ]]; then
        local port
        port="$(vm_get_port "$name")"
        [[ -n "$port" ]] && echo "  SSH port:  $port"
    fi
    echo ""
}

# cvm start <name>
cmd_start() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: cvm start <name>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found."

    local backend
    backend="$(registry_get_field "$name" backend)"

    if [[ "$backend" == "docker" ]]; then
        info "Docker VMs don't require explicit start (containers are ephemeral per task)."
        return 0
    fi

    if vm_is_running "$name" "$backend"; then
        info "VM '$name' is already running."
        return 0
    fi

    check_deps
    vm_named_start "$name"
}

# cvm stop <name>
cmd_stop() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: cvm stop <name>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found."

    local backend
    backend="$(registry_get_field "$name" backend)"

    if [[ "$backend" == "docker" ]]; then
        info "Docker VMs don't require explicit stop (containers are ephemeral per task)."
        return 0
    fi

    if ! vm_is_running "$name" "$backend"; then
        info "VM '$name' is not running."
        return 0
    fi

    vm_named_stop "$name"
}

# cvm run <name> [--dir D] [--out O] [--model M] [--budget B] [-v] "task"
cmd_run() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: cvm run <name> [OPTIONS] \"task\""
    shift

    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found. Use 'cvm spinup' to create one."

    local backend workspace
    backend="$(registry_get_field   "$name" backend)"
    workspace="$(registry_get_field "$name" workspace)"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)     [[ $# -lt 2 ]] && die "--dir requires an argument";    DIR="$2";    shift 2 ;;
            -o|--out)     [[ $# -lt 2 ]] && die "--out requires an argument";    OUT="$2";    shift 2 ;;
            -m|--model)   [[ $# -lt 2 ]] && die "--model requires an argument";  MODEL="$2";  shift 2 ;;
            -b|--budget)  [[ $# -lt 2 ]] && die "--budget requires an argument"; BUDGET="$2"; shift 2 ;;
            -v|--verbose) VERBOSE=true; shift ;;
            --) shift; TASK="${*}"; break ;;
            -*) die "Unknown option: $1" ;;
            *)  TASK="${*}"; break ;;
        esac
    done

    if [[ -z "$TASK" ]] && [[ ! -t 0 ]]; then
        TASK="$(cat)"
    fi
    [[ -z "$TASK" ]] && die "No task provided."

    WORKSPACE="$workspace"

    if [[ -n "$DIR" ]]; then
        [[ -d "$DIR" ]] || die "Directory not found: $DIR"
        cp -r "$DIR/." "$WORKSPACE/"
        chmod -R a+rw "$WORKSPACE"
    fi

    check_auth

    local exit_code=0

    case "$backend" in
        kvm|virtualbox)
            check_deps
            if ! vm_is_running "$name" "$backend"; then
                info "Auto-starting VM '$name'..."
                vm_named_start "$name"
            fi
            local port
            port="$(vm_get_port "$name")"
            [[ -z "$port" ]] && die "Could not get SSH port for VM '$name'"

            vm_setup_claude_auth localhost "$port"
            vm_copy_workspace_in localhost "$port"

            echo ""
            info "Task: ${BOLD}${TASK}${RESET}"
            info "Model: $MODEL"
            [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
            echo ""

            vm_run_claude_ssh localhost "$port" || exit_code=$?
            vm_copy_workspace_out localhost "$port"
            ;;
        docker)
            BACKEND="docker"
            check_deps
            compute_image_hash
            ensure_image

            echo ""
            info "Task: ${BOLD}${TASK}${RESET}"
            info "Model: $MODEL"
            [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
            echo ""

            docker_vm_run_claude "$name" || exit_code=$?
            ;;
        *)
            die "Unknown backend: $backend"
            ;;
    esac

    if [[ -n "$OUT" ]]; then
        mkdir -p "$OUT"
        cp -r "$WORKSPACE/." "$OUT/"
        success "Results copied to: $OUT"
    fi

    show_file_summary

    if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
        warn "Claude exited with code $exit_code"
    fi
    return $exit_code
}

# cvm rename <name> <new-name>
cmd_rename() {
    local name="${1:-}" new_name="${2:-}"
    [[ -z "$name" || -z "$new_name" ]] && die "Usage: cvm rename <name> <new-name>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found."
    validate_vm_name "$new_name"

    if registry_exists "$new_name"; then
        die "VM '$new_name' already exists."
    fi

    local backend
    backend="$(registry_get_field "$name" backend)"

    case "$backend" in
        kvm)        kvm_vm_rename   "$name" "$new_name" ;;
        virtualbox) vbox_vm_rename  "$name" "$new_name" ;;
        docker)     docker_vm_rename "$name" "$new_name" ;;
        *) die "Unknown backend: $backend" ;;
    esac

    python3 - "$CVM_REGISTRY" "$name" "$new_name" "$CVM_VMS_DIR" <<'PYEOF'
import json, sys
reg_file, name, new_name, vms_dir = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open(reg_file) as f:
    data = json.load(f)
vm = data.pop(name)
vm['name'] = new_name
for key in ('disk', 'workspace'):
    if key in vm and vm[key]:
        vm[key] = vm[key].replace(f'/{name}/', f'/{new_name}/', 1)
if 'vbox_name' in vm:
    vm['vbox_name'] = f'cvm-{new_name}'
data[new_name] = vm
with open(reg_file, 'w') as f:
    json.dump(data, f, indent=2)
PYEOF

    success "VM '$name' renamed to '$new_name'"
}

# cvm move <name> <dest-path>
cmd_move() {
    local name="${1:-}" dest="${2:-}"
    [[ -z "$name" || -z "$dest" ]] && die "Usage: cvm move <name> <dest-path>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found."

    local backend
    backend="$(registry_get_field "$name" backend)"
    dest="$(realpath -m "$dest")"

    case "$backend" in
        kvm)        kvm_vm_move    "$name" "$dest" ;;
        virtualbox) vbox_vm_move   "$name" "$dest" ;;
        docker)     docker_vm_move "$name" "$dest" ;;
        *) die "Unknown backend: $backend" ;;
    esac

    python3 - "$CVM_REGISTRY" "$name" "$dest" <<'PYEOF'
import json, sys, os
reg_file, name, dest = sys.argv[1], sys.argv[2], sys.argv[3]
with open(reg_file) as f:
    data = json.load(f)
vm = data[name]
new_base = os.path.join(dest, name)
for key in ('disk', 'workspace'):
    if key in vm and vm[key]:
        vm[key] = os.path.join(new_base, os.path.basename(vm[key]))
with open(reg_file, 'w') as f:
    json.dump(data, f, indent=2)
PYEOF

    success "VM '$name' moved to $dest/$name"
}

# cvm delete <name>
cmd_delete() {
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: cvm delete <name>"
    setup_colors
    registry_ensure
    registry_exists "$name" || die "VM '$name' not found."

    local backend
    backend="$(registry_get_field "$name" backend)"

    info "Deleting VM '$name' (backend: $backend)..."

    case "$backend" in
        kvm)        kvm_vm_delete    "$name" ;;
        virtualbox) vbox_vm_delete   "$name" ;;
        docker)     docker_vm_delete "$name" ;;
        *) die "Unknown backend: $backend" ;;
    esac

    registry_delete "$name"
    success "VM '$name' deleted"
}

# ── File summary ──────────────────────────────────────────────────────────────
show_file_summary() {
    if [[ ! -d "$WORKSPACE" ]]; then return; fi

    local file_count
    file_count="$(find "$WORKSPACE" -type f | wc -l)"

    if [[ "$file_count" -eq 0 ]]; then
        info "Workspace: no files created"
        return
    fi

    local total_size
    total_size="$(du -sh "$WORKSPACE" 2>/dev/null | cut -f1)"

    echo ""
    info "Workspace contents (${file_count} files, ${total_size} total):"
    find "$WORKSPACE" -type f | sort | while read -r f; do
        local rel="${f#$WORKSPACE/}"
        local sz
        sz="$(du -sh "$f" 2>/dev/null | cut -f1)"
        echo -e "  ${DIM}${sz}${RESET}  ${rel}"
    done
}

# ── Stream-JSON parser ────────────────────────────────────────────────────────
# Used only in --verbose mode to pretty-print tool calls and cost info.
# Note: python3 reads the script from a temp file so that stdin remains
# connected to the docker/ssh pipe (a heredoc would consume stdin for the script).
STREAM_JSON_PARSER=""

write_stream_json_parser() {
    STREAM_JSON_PARSER="$(mktemp /tmp/cvm-parser-XXXXXX.py)"
    cat > "$STREAM_JSON_PARSER" <<'PYEOF'
import sys, json

for line in sys.stdin:
    line = line.rstrip('\n')
    if not line:
        continue
    try:
        obj = json.loads(line)
    except json.JSONDecodeError:
        print(line)
        continue

    t = obj.get('type', '')

    if t == 'text':
        text = obj.get('text', '')
        if text:
            print(text, end='', flush=True)

    elif t == 'tool_use':
        name = obj.get('name', '')
        inp = obj.get('input', {})
        print(f'\n\033[36m[tool: {name}]\033[0m', flush=True)
        if isinstance(inp, dict):
            for k, v in inp.items():
                v_str = str(v)
                if len(v_str) > 200:
                    v_str = v_str[:200] + '...'
                print(f'  {k}: {v_str}')

    elif t == 'tool_result':
        content = obj.get('content', '')
        if isinstance(content, str) and content:
            truncated = content[:300] + '...' if len(content) > 300 else content
            print(f'\033[2m  \u2192 {truncated}\033[0m', flush=True)

    elif t == 'result':
        cost = obj.get('cost_usd')
        usage = obj.get('usage', {})
        turns = obj.get('num_turns')
        print('', flush=True)
        if cost is not None:
            print(f'\033[32m[cvm] cost: ${cost:.4f} USD\033[0m')
        if turns is not None:
            print(f'\033[2m[cvm] turns: {turns}\033[0m')
        if usage:
            inp_tok = usage.get('input_tokens', 0)
            out_tok = usage.get('output_tokens', 0)
            print(f'\033[2m[cvm] tokens: {inp_tok} in / {out_tok} out\033[0m')

    elif t == 'error':
        msg = obj.get('message', str(obj))
        print(f'\033[31m[error] {msg}\033[0m', file=sys.stderr)

    else:
        raw = obj.get('text') or obj.get('content') or ''
        if raw:
            print(raw, end='', flush=True)
PYEOF
}

parse_stream_json() {
    python3 -u "$STREAM_JSON_PARSER"
}

# ── Cleanup ───────────────────────────────────────────────────────────────────
cleanup() {
    local exit_code=$?

    # VM-specific teardown
    case "${BACKEND:-}" in
        kvm)
            if [[ -n "$VM_PID" ]]; then
                kill "$VM_PID" &>/dev/null || true
                wait "$VM_PID" 2>/dev/null || true
                VM_PID=""
            fi
            ;;
        virtualbox)
            if [[ -n "$VM_NAME" ]]; then
                VBoxManage controlvm "$VM_NAME" poweroff &>/dev/null || true
                sleep 2
                VBoxManage unregistervm "$VM_NAME" --delete &>/dev/null || true
                VM_NAME=""
            fi
            ;;
        vmware)
            if [[ -n "$VM_TASK_DIR" ]] && [[ -f "$VM_TASK_DIR/ubuntu.vmx" ]]; then
                vmrun -T "${VMWARE_PROVIDER:-ws}" stop "$VM_TASK_DIR/ubuntu.vmx" hard \
                    &>/dev/null || true
                rm -rf "$VM_TASK_DIR"
                VM_TASK_DIR=""
            fi
            ;;
    esac

    # Copy output if requested
    if [[ -n "$OUT" ]] && [[ -d "$WORKSPACE" ]]; then
        mkdir -p "$OUT"
        cp -r "$WORKSPACE/." "$OUT/"
        success "Workspace copied to: $OUT"
    fi

    # Remove workspace unless --keep
    if [[ "$KEEP" == "false" ]] && [[ -d "$WORKSPACE" ]]; then
        rm -rf "$WORKSPACE"
    elif [[ "$KEEP" == "true" ]] && [[ -d "$WORKSPACE" ]]; then
        info "Workspace kept at: $WORKSPACE"
    fi

    # Clean up temp files
    [[ -n "$STREAM_JSON_PARSER" ]] && rm -f "$STREAM_JSON_PARSER"
    [[ -n "$CLAUDE_TMP" ]] && rm -rf "$CLAUDE_TMP"

    exit $exit_code
}

handle_interrupt() {
    echo ""
    warn "Interrupted — stopping..."
    case "${BACKEND:-}" in
        docker)
            docker stop "cvm-$$" &>/dev/null || true ;;
        kvm)
            [[ -n "$VM_PID" ]] && kill "$VM_PID" &>/dev/null || true ;;
        virtualbox)
            [[ -n "$VM_NAME" ]] && \
                VBoxManage controlvm "$VM_NAME" poweroff &>/dev/null || true ;;
        vmware)
            if [[ -n "$VM_TASK_DIR" ]] && [[ -f "$VM_TASK_DIR/ubuntu.vmx" ]]; then
                vmrun -T "${VMWARE_PROVIDER:-ws}" stop "$VM_TASK_DIR/ubuntu.vmx" hard \
                    &>/dev/null || true
            fi
            ;;
    esac
    [[ -n "$CLAUDE_TMP" ]] && rm -rf "$CLAUDE_TMP"
    [[ -n "$STREAM_JSON_PARSER" ]] && rm -f "$STREAM_JSON_PARSER"
    exit 130
}

# ── Docker run ────────────────────────────────────────────────────────────────
docker_run_claude() {
    local image_tag="cvm:${IMAGE_HASH}"

    # Build docker run arguments
    local docker_args=(
        run
        --rm
        --name "cvm-$$"
        -v "${WORKSPACE}:/workspace"
        -e "TERM=xterm-256color"
        -w /workspace
        --network bridge
    )

    # Mount writable temp ~/.claude dir (contains copied credentials/settings).
    docker_args+=(-v "$CLAUDE_TMP:/home/ubuntu/.claude")
    # Also mount ~/.claude.json (top-level config file, separate from ~/.claude/)
    if [[ -f "$HOME/.claude.json" ]]; then
        docker_args+=(-v "$HOME/.claude.json:/home/ubuntu/.claude.json:ro")
    fi
    docker_args+=(-e "HOME=/home/ubuntu")

    # Pass API key if set
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        docker_args+=(-e "ANTHROPIC_API_KEY")
    fi

    docker_args+=("$image_tag")

    # Build claude command arguments
    local claude_args=(
        claude
        --dangerously-skip-permissions
        --no-session-persistence
        -p "$TASK"
        --model "$MODEL"
    )

    if [[ -n "$BUDGET" ]]; then
        claude_args+=(--max-budget-usd "$BUDGET")
    fi

    if [[ "$VERBOSE" == "true" ]]; then
        claude_args+=(--output-format stream-json --verbose)
    fi

    echo ""
    info "Task: ${BOLD}${TASK}${RESET}"
    info "Model: $MODEL"
    [[ -n "$BUDGET" ]] && info "Budget: \$$BUDGET"
    echo ""

    local exit_code=0
    if [[ "$VERBOSE" == "true" ]]; then
        write_stream_json_parser
        docker "${docker_args[@]}" "${claude_args[@]}" | parse_stream_json
        exit_code=${PIPESTATUS[0]}
    else
        docker "${docker_args[@]}" "${claude_args[@]}"
        exit_code=$?
    fi

    if [[ $exit_code -ne 0 ]] && [[ $exit_code -ne 130 ]]; then
        echo ""
        warn "Claude exited with code $exit_code"
    fi

    show_file_summary

    return $exit_code
}

# ── Run dispatcher ────────────────────────────────────────────────────────────
run_claude() {
    # Register signal handlers (all backends)
    trap 'handle_interrupt' INT TERM
    trap 'cleanup' EXIT

    case "$BACKEND" in
        docker)     docker_run_claude ;;
        kvm)        kvm_run_claude ;;
        virtualbox) vbox_run_claude ;;
        vmware)     vmware_run_claude ;;
    esac
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    # Detect and dispatch named VM subcommands before one-shot flag parsing.
    local subcommand="${1:-}"
    case "$subcommand" in
        spinup)   shift; cmd_spinup  "$@"; return ;;
        list|ls)  shift; cmd_list    "$@"; return ;;
        start)    shift; cmd_start   "$@"; return ;;
        stop)     shift; cmd_stop    "$@"; return ;;
        run)      shift; cmd_run     "$@"; return ;;
        rename)   shift; cmd_rename  "$@"; return ;;
        move)     shift; cmd_move    "$@"; return ;;
        delete)   shift; cmd_delete  "$@"; return ;;
        status)   shift; cmd_status  "$@"; return ;;
    esac

    # One-shot mode (original behavior, unchanged)
    parse_args "$@"
    setup_colors
    detect_backend
    check_deps
    check_auth
    ensure_image
    create_workspace
    run_claude
}

main "$@"
